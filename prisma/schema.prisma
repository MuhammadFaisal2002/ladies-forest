// Ladies Forest — Prisma schema
// Core concept (PROJECT_CONTEXT.md §4): flexible Shopify-style options/variants.
// A Product has 0+ Options (e.g. "Size", "Cup"); each combination of option
// values = one Variant. Every Variant owns its own price, stock and SKU.
// All money values are whole PKR rupees stored as Int (no paisa on the store).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Catalog ----------

enum ProductStatus {
  ACTIVE
  DRAFT
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  bannerImage String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String          @id @default(cuid())
  title          String
  slug           String          @unique
  description    String          @default("")
  images         String[]
  // basePrice is the display/fallback price; each variant still owns its real price
  basePrice      Int
  compareAtPrice Int?
  status         ProductStatus   @default(DRAFT)
  featured       Boolean         @default(false)
  tags           String[]
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId     String?
  options        ProductOption[]
  variants       Variant[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId, status])
}

model ProductOption {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  name      String // e.g. "Size", "Cup", "Volume"
  values    String[] // e.g. ["32","34","36","38","40","42"]
  sortOrder Int      @default(0)

  @@unique([productId, name])
}

model Variant {
  id                String            @id @default(cuid())
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String
  // JSON map of option name -> value, e.g. {"Size":"34","Cup":"B"}
  optionValues      Json              @default("{}")
  // Human label derived from optionValues, e.g. "34 / B" ("Default" when no options)
  title             String            @default("Default")
  sku               String?           @unique
  price             Int
  stock             Int               @default(0)
  lowStockThreshold Int               @default(5)
  stockAdjustments  StockAdjustment[]
  orderItems        OrderItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([productId])
}

model StockAdjustment {
  id          String     @id @default(cuid())
  variant     Variant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId   String
  change      Int // +10 restock, -1 sale, etc.
  reason      String
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  adminUserId String?
  createdAt   DateTime   @default(now())

  @@index([variantId])
}

// ---------- Orders ----------

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique // e.g. "LF-1001"
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId    String? // null = guest checkout
  items         OrderItem[]
  subtotal      Int
  discountTotal Int           @default(0)
  shippingTotal Int           @default(0)
  grandTotal    Int
  couponCode    String?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(COD)
  paymentStatus PaymentStatus @default(PENDING)
  // Snapshot of the shipping address at purchase time
  shipName      String
  shipPhone     String
  shipEmail     String?
  shipAddress   String
  shipCity      String
  shipProvince  String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([customerId])
}

model OrderItem {
  id           String   @id @default(cuid())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  variant      Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId    String?
  // Snapshots so the order survives product/variant deletion or edits
  productTitle String
  variantTitle String
  sku          String?
  image        String?
  price        Int // price at purchase
  quantity     Int

  @@index([orderId])
}

// ---------- Customers ----------

model Customer {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  passwordHash  String?
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Address {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  fullName   String
  phone      String
  address    String
  city       String
  province   String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model WishlistItem {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
}

// ---------- Discounts ----------

enum DiscountType {
  PERCENT
  FIXED
}

enum DiscountScope {
  ALL
  CATEGORY
  PRODUCT
}

model Discount {
  id            String        @id @default(cuid())
  code          String        @unique
  type          DiscountType
  value         Int // percent (1-100) or fixed PKR amount
  minOrderValue Int?
  appliesTo     DiscountScope @default(ALL)
  targetId      String? // categoryId or productId when scoped
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int           @default(0)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ---------- CMS & Settings ----------

// Key-value store for admin-editable settings:
// freeDeliveryThreshold, announcementText, shippingFee, storeInfo,
// paymentMethodsEnabled, seoDefaults, whatsappNumber, socialLinks ...
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id         String   @id @default(cuid())
  image      String
  heading    String?
  subheading String?
  ctaText    String?
  ctaHref    String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// ---------- Admin ----------

enum AdminRole {
  ADMIN
  STAFF
}

model AdminUser {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             AdminRole         @default(STAFF)
  stockAdjustments StockAdjustment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// ---------- Reviews (optional phase) ----------

model Review {
  id         String    @id @default(cuid())
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?
  authorName String
  rating     Int // 1-5
  comment    String
  approved   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([productId, approved])
}
